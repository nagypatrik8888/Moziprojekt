    {
      "name": "http://localhost:8888/api/movies",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Content-Type is application/json\", () => {\r",
              "    pm.response.to.have.header(\"Content-Type\");\r",
              "    const ct = pm.response.headers.get(\"Content-Type\");\r",
              "    pm.expect(ct).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is under 2000ms\", () => {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "let jsonData;\r",
              "pm.test(\"Response body is valid JSON with movies and genres\", () => {\r",
              "    jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.be.an(\"object\");\r",
              "    pm.expect(jsonData).to.have.property(\"movies\");\r",
              "    pm.expect(jsonData).to.have.property(\"genres\");\r",
              "});\r",
              "\r",
              "pm.test(\"Movies is an array and has at least one item\", () => {\r",
              "    pm.expect(jsonData.movies).to.be.an(\"array\");\r",
              "    pm.expect(jsonData.movies.length).to.be.at.least(1);\r",
              "});\r",
              "\r",
              "pm.test(\"Each movie has required fields with correct types\", () => {\r",
              "    jsonData.movies.forEach((m) => {\r",
              "        pm.expect(m).to.be.an(\"object\");\r",
              "        pm.expect(m).to.have.property(\"title\").that.is.a(\"string\");\r",
              "        pm.expect(m).to.have.property(\"movie_id\").that.is.a(\"number\");\r",
              "        pm.expect(m).to.have.property(\"genre_name\").that.is.a(\"string\");\r",
              "        pm.expect(m).to.have.property(\"release_date\").that.is.a(\"string\");\r",
              "        // Check release_date parseable as date\r",
              "        const d = Date.parse(m.release_date);\r",
              "        pm.expect(isNaN(d)).to.be.false;\r",
              "        pm.expect(m).to.have.property(\"rating\").that.is.a(\"number\");\r",
              "        pm.expect(m.rating).to.be.within(0, 10);\r",
              "        pm.expect(m).to.have.property(\"duration\").that.is.a(\"number\");\r",
              "        pm.expect(m).to.have.property(\"description\").that.is.a(\"string\");\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Genres is an array of objects with genre_name\", () => {\r",
              "    pm.expect(jsonData.genres).to.be.an(\"array\");\r",
              "    jsonData.genres.forEach((g) => {\r",
              "        pm.expect(g).to.be.an(\"object\");\r",
              "        pm.expect(g).to.have.property(\"genre_name\").that.is.a(\"string\");\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.environment.set('XSRF', decodeURIComponent(pm.cookies.get('XSRF-TOKEN')));\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
